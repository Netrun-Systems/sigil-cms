# NetrunCMS API Environment Variables

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/netrun_cms
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=20

# Authentication
JWT_SECRET=your-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
