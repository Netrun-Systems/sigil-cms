# Sigil CMS API Environment Variables

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database Configuration (Drizzle ORM — CMS tables)
DATABASE_URL=postgresql://user:password@localhost:5432/netrun_cms
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=20

# Authentication
JWT_SECRET=your-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Gemini AI (for advisor + photo curation + Resonance suggestions)
GEMINI_API_KEY=your-gemini-api-key

# pgvector RAG (for advisor document ingestion and semantic search)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=charlotte_db
DB_USER=charlotte_user
DB_PASS=your-charlotte-db-password
CMS_ADVISOR_COLLECTION=ncms_advisor

# ── Object Storage (Photos Plugin) ──────────────────
# Set ONE provider. Auto-detects from credentials if STORAGE_PROVIDER is not set.
# Default: Google Cloud Storage (for headless GCloud operation)

# Option A: Google Cloud Storage (default)
STORAGE_PROVIDER=gcs
GCS_BUCKET=sigil-media
GCS_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option B: Azure Blob Storage
# STORAGE_PROVIDER=azure
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# STORAGE_BUCKET=sigil-media

# Option C: AWS S3 (or S3-compatible: MinIO, DigitalOcean Spaces, Backblaze B2)
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET=sigil-media
# S3_ENDPOINT=https://your-s3-compatible-endpoint  # for MinIO/Spaces/B2

# ── Commerce Plugins ────────────────────────────────
# STRIPE_SECRET_KEY=sk_...
# PRINTFUL_API_KEY=your-printful-api-key
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-secret
# PAYPAL_SANDBOX=true

# ── Booking Plugin (optional Google Calendar sync) ──
# GOOGLE_CALENDAR_CREDENTIALS={"type":"service_account",...}
# GOOGLE_CALENDAR_ID=your-calendar@group.calendar.google.com

# ── Email Notifications (optional ACS) ──────────────
# ACS_CONNECTION_STRING=endpoint=https://...
# ACS_SENDER_ADDRESS=charlotte@netrunsystems.com
