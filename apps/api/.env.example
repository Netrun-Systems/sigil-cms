# NetrunCMS API Environment Variables

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database Configuration (Drizzle ORM — CMS tables)
DATABASE_URL=postgresql://user:password@localhost:5432/netrun_cms
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=20

# Authentication
JWT_SECRET=your-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Gemini AI (for advisor + photo curation)
GEMINI_API_KEY=your-gemini-api-key

# pgvector RAG (charlotte_db on Cloud SQL — shared with frost)
# Used for advisor document ingestion and semantic search
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=charlotte_db
DB_USER=charlotte_user
DB_PASS=your-charlotte-db-password
CMS_ADVISOR_COLLECTION=ncms_advisor

# Azure Blob Storage (for photo management)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
PHOTOS_CONTAINER=cms-photos
