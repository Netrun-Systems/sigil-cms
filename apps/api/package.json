    "@netrun-cms/plugin-runtime": "workspace:*",
    "@netrun-cms/theme": "workspace:*",
    "@netrun-cms/plugin-seo": "workspace:*",
    "@netrun-cms/plugin-artist": "workspace:*",
    "@netrun-cms/plugin-mailing-list": "workspace:*",
    "@netrun-cms/plugin-contact": "workspace:*",
    "@netrun-cms/plugin-photos": "workspace:*",
    "@netrun-cms/plugin-advisor": "workspace:*",
    "@netrun-cms/plugin-store": "workspace:*",
    "@netrun-cms/plugin-printful": "workspace:*",
    "@netrun-cms/plugin-paypal": "workspace:*",
    "@netrun-cms/plugin-booking": "workspace:*",
