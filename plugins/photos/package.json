{
  "name": "@netrun-cms/plugin-photos",
  "version": "2.0.0",
  "description": "Photo management for Sigil CMS — GCS, Azure Blob, or S3 storage + AI curation",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external @azure/storage-blob --external @google-cloud/storage --external @aws-sdk/client-s3",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@netrun-cms/plugin-runtime": "workspace:*",
    "@netrun-cms/db": "workspace:*",
    "@google/genai": "^0.7.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/pg": "^8.11.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "express": "^4.21.0",
    "drizzle-orm": "^0.39.0",
    "pg": "^8.13.0"
  }
}
