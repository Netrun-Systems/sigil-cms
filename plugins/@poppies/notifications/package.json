{
  "name": "@poppies/notifications",
  "version": "1.0.0",
  "description": "Notification system for Poppies — email, SMS, push notifications with per-artist preferences",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@netrun-cms/plugin-runtime": "workspace:*",
    "@netrun-cms/db": "workspace:*",
    "web-push": "^3.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/web-push": "^3.6.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "express": "^4.21.0",
    "drizzle-orm": "^0.39.0"
  }
}
