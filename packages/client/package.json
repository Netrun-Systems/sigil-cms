{
  "name": "@sigil-cms/client",
  "version": "0.1.0",
  "description": "TypeScript client SDK for Sigil CMS — fetch content from any Sigil instance in Next.js, Nuxt, Astro, or plain Node.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "cms",
    "headless-cms",
    "sigil",
    "content-management",
    "sdk",
    "client"
  ],
  "author": "Netrun Systems <dev@netrunsystems.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Netrun-Systems/netrun-cms",
    "directory": "packages/client"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
