{
  "name": "@netrun-cms/theme",
  "version": "1.0.0",
  "description": "Theme system for NetrunCMS with dark/light modes and customization",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./presets": {
      "import": "./dist/presets.mjs",
      "require": "./dist/presets.js",
      "types": "./dist/presets.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/presets.ts --format cjs,esm --dts --external react",
    "dev": "tsup src/index.ts src/presets.ts --format cjs,esm --dts --external react --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@netrun-cms/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
