{
  "name": "@netrun-cms/blocks",
  "version": "1.0.0",
  "description": "Content block components for NetrunCMS - adapted from NetrunnewSite landing components",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react",
    "dev": "tsup src/index.ts --format cjs,esm --dts --external react --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@netrun-cms/core": "workspace:*",
    "@netrun-cms/ui": "workspace:*",
    "@netrun-cms/theme": "workspace:*",
    "lucide-react": "^0.460.0",
    "react-markdown": "^9.0.0",
    "dompurify": "^3.0.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
