{
  "name": "@netrun-cms/plugin-runtime",
  "version": "1.0.0",
  "description": "Plugin runtime for NetrunCMS — loader, registry, and manifest",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external @google-cloud/storage --external @azure/storage-blob --external @aws-sdk/client-s3",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@netrun/platform-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "express": "^4.21.0",
    "drizzle-orm": "^0.39.0"
  }
}
