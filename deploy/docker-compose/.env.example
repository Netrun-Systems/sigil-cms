# =============================================================================
# Sigil CMS — Docker Compose Environment Variables
# Copy this file to .env and update values before starting.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Password for the PostgreSQL sigil user. CHANGE THIS in production.
DB_PASSWORD=your-secure-password-here

# Host port for PostgreSQL (default: 5432). Change if 5432 is in use.
DB_PORT=5432

# --- API Server --------------------------------------------------------------
# Secret key for signing JWT auth tokens. Generate with: openssl rand -hex 32
JWT_SECRET=generate-a-random-256-bit-key

# Bootstrap API key used to create the first tenant. Disable after setup.
SEED_API_KEY=your-bootstrap-key

# Host port for the API (default: 3001)
API_PORT=3001

# --- Stripe (optional) ------------------------------------------------------
# Stripe secret key for billing integration. Leave empty to disable.
STRIPE_SECRET_KEY=

# --- Admin Panel -------------------------------------------------------------
# Host port for the admin panel (default: 3000)
ADMIN_PORT=3000

# --- Renderer ----------------------------------------------------------------
# Host port for the SSR renderer (default: 4000)
RENDERER_PORT=4000

# Tenant slug the renderer serves. Must match a tenant created via the API.
SITE_SLUG=default

# Display name shown in the rendered site header/title.
SITE_NAME=My Site

# --- Stock Images (optional) -------------------------------------------------
# API keys for stock image integrations in the admin panel.
VITE_UNSPLASH_KEY=
VITE_PEXELS_KEY=
