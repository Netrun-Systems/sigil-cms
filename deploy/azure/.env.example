# =============================================================================
# Sigil CMS — Azure Container Apps Environment Variables
# These are managed via Azure Key Vault and Container App secrets.
# This file is for reference only.
# =============================================================================

# --- Azure Configuration -----------------------------------------------------
# Resource group name
RESOURCE_GROUP=sigil-rg

# Azure region
LOCATION=eastus2

# --- Database ----------------------------------------------------------------
# Managed by deploy.sh — stored in Azure Key Vault as sigil-db-password.
# PostgreSQL Flexible Server: Burstable B1ms, PostgreSQL 16.
# DB_PASSWORD is auto-generated on first deploy.

# --- API Server --------------------------------------------------------------
# Stored in Key Vault as sigil-jwt-secret. Auto-generated on first deploy.
# JWT_SECRET=

# Stored in Key Vault as sigil-seed-key. Auto-generated on first deploy.
# SEED_API_KEY=

# --- Stripe (optional) ------------------------------------------------------
# Add via Container App secrets:
#   az containerapp secret set --name sigil-api --resource-group sigil-rg --secrets "stripe-key=sk_live_..."
STRIPE_SECRET_KEY=

# --- Renderer ----------------------------------------------------------------
# Tenant slug the renderer serves.
SITE_SLUG=default

# Display name shown in the rendered site.
SITE_NAME=My Site

# --- Stock Images (optional) -------------------------------------------------
VITE_UNSPLASH_KEY=
VITE_PEXELS_KEY=
