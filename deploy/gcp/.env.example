# =============================================================================
# Sigil CMS — Google Cloud Run Environment Variables
# These are managed via gcloud run deploy --set-env-vars or Secret Manager.
# This file is for reference only.
# =============================================================================

# --- GCP Project -------------------------------------------------------------
# GCP project ID (required for deploy.sh)
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Run region
GCP_REGION=us-central1

# --- Database ----------------------------------------------------------------
# Managed by deploy.sh — stored in Secret Manager as sigil-db-password.
# Cloud Run connects via Unix socket: postgresql://sigil:<password>@/sigil?host=/cloudsql/<connection-name>
# DB_PASSWORD is auto-generated on first deploy.

# --- API Server --------------------------------------------------------------
# Stored in Secret Manager as sigil-jwt-secret. Auto-generated on first deploy.
# JWT_SECRET=

# Stored in Secret Manager as sigil-seed-key. Auto-generated on first deploy.
# SEED_API_KEY=

# --- Stripe (optional) ------------------------------------------------------
# Add via: gcloud run services update sigil-api --set-env-vars STRIPE_SECRET_KEY=sk_live_...
STRIPE_SECRET_KEY=

# --- Renderer ----------------------------------------------------------------
# Tenant slug the renderer serves.
SITE_SLUG=default

# Display name shown in the rendered site.
SITE_NAME=My Site

# --- Stock Images (optional) -------------------------------------------------
VITE_UNSPLASH_KEY=
VITE_PEXELS_KEY=
