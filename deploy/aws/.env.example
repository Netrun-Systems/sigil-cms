# =============================================================================
# Sigil CMS — AWS Fargate Environment Variables
# These are managed via AWS Secrets Manager and ECS task definitions.
# This file is for reference only.
# =============================================================================

# --- AWS Configuration -------------------------------------------------------
# AWS region for all resources
AWS_REGION=us-east-1

# Stack name prefix for all resources (ECR, ECS, RDS, ALB)
STACK_NAME=sigil

# --- Database ----------------------------------------------------------------
# Managed by deploy.sh — stored in AWS Secrets Manager as sigil/db-password.
# RDS endpoint is auto-discovered. Instance class: db.t4g.micro (free tier eligible).
# DB_PASSWORD is auto-generated on first deploy.

# --- API Server --------------------------------------------------------------
# Stored in AWS Secrets Manager as sigil/jwt-secret. Auto-generated on first deploy.
# JWT_SECRET=

# Stored in AWS Secrets Manager as sigil/seed-key. Auto-generated on first deploy.
# SEED_API_KEY=

# --- Stripe (optional) ------------------------------------------------------
# Add via ECS task definition environment or Secrets Manager.
STRIPE_SECRET_KEY=

# --- Renderer ----------------------------------------------------------------
# Tenant slug the renderer serves.
SITE_SLUG=default

# Display name shown in the rendered site.
SITE_NAME=My Site

# --- Stock Images (optional) -------------------------------------------------
VITE_UNSPLASH_KEY=
VITE_PEXELS_KEY=
