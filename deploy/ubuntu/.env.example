# =============================================================================
# Sigil CMS — Ubuntu Bare Metal Environment Variables
# The install.sh script auto-generates this file at /opt/sigil/.env
# =============================================================================

# --- Server ------------------------------------------------------------------
# Environment (always production for deployed instances)
NODE_ENV=production

# Port the API listens on (nginx proxies to this)
PORT=3001

# Bind address (127.0.0.1 = local only via nginx, 0.0.0.0 = direct access)
HOST=127.0.0.1

# --- Database ----------------------------------------------------------------
# PostgreSQL connection string. Auto-generated by install.sh.
DATABASE_URL=postgresql://sigil:your-password-here@localhost:5432/sigil

# --- Authentication ----------------------------------------------------------
# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=generate-a-random-256-bit-key

# Bootstrap API key for creating the first tenant. Disable after setup.
SEED_API_KEY=your-bootstrap-key

# --- Stripe (optional) ------------------------------------------------------
# Stripe secret key for billing integration. Leave empty to disable.
STRIPE_SECRET_KEY=

# --- Stock Images (optional) -------------------------------------------------
# API keys for stock image integrations in the admin panel.
VITE_UNSPLASH_KEY=
VITE_PEXELS_KEY=
