# Git
.git
.gitignore

# Dependencies (reinstalled in Docker)
# NOTE: apps/api/node_modules is intentionally NOT excluded — needed by the production image
node_modules
**/node_modules
!apps/api/node_modules

# Build artifacts (rebuilt in Docker)
# NOTE: apps/api/dist and apps/admin/dist are intentionally NOT excluded —
# the production Dockerfiles use pre-built artifacts
**/dist
!apps/api/dist
!apps/admin/dist
**/.turbo

# Development files
.env*
!.env.example
*.md
!README.md
docs/
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Test files
**/__tests__
**/*.test.ts
**/*.spec.ts
coverage/

# CI/CD
.github/
azure-pipelines.yml
pipelines/
deploy/
